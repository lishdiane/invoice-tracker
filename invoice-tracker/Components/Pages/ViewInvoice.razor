@page "/invoices/view/{id:int}"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using System.Text

@inject InvoiceTrackerContext Context
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject UserSession UserSession

<PageTitle>Invoice Details</PageTitle>


@if (showConfirm)
{
    <div class="modal-backdrop-custom">
        <div class="custom-modal">
            <div class="alert alert-warning d-flex justify-content-between align-items-center">
                <span>Are you sure you want to delete this invoice?</span>

                <div class="d-flex gap-2">
                    <button class="btn btn-danger btn-sm" @onclick="ConfirmDelete">
                        Yes
                    </button>

                    <button class="btn btn-secondary btn-sm" @onclick="CancelDelete">
                        No
                    </button>
                </div>
            </div>
        </div>
    </div>
    
}
@if (isLoading)
{
    <p>Loading...</p>
}
else if (invoice == null)
{
    <div class="alert alert-danger">
        Invoice not found.
    </div>
    <button class="btn btn-secondary" @onclick="BackToList">
        Back
    </button>
}
else
{
    <div class="card page-content invoice-details">
        <h1>Invoice Details</h1>

        @* Invoice Information *@
        <div>
            <h2 class="pt-3">Invoice #@invoice.InvoiceId</h2>
            <div class="page-content">

                <p>
                    <strong>Client:</strong>
                    @invoice.Client?.ClientName
                </p>

                <p>
                    <strong>Invoice Date:</strong>
                    @invoice.InvoiceDate.ToShortDateString()
                </p>

                <p>
                    <strong>Due Date:</strong>
                    @invoice.DueDate.ToShortDateString()
                </p>

                <p>
                    <strong>Status:</strong>
                    <span class="invoice-status @(invoice.IsPaid ? "paid" : "unpaid")">
                        @(invoice.IsPaid ? "Paid" : "Unpaid")
                    </span>
                </p>
            </div>

            @* Product List *@
            @if (invoice.InvoiceProducts != null &&
                invoice.InvoiceProducts.Any())
            {
                <h2 class="pt-3">Products</h2>
                <div class="page-content">
                    <table class=" custom-table table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in invoice.InvoiceProducts)
                            {
                                <tr>
                                    <td>@item.Product.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.Price.ToString("C", new System.Globalization.CultureInfo("en-US"))</td>
                                    <td>@((item.Quantity * item.Price).ToString("C", new System.Globalization.CultureInfo("en-US")))
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <h5 class="grand-total">
                    Grand Total:
                    @(invoice.InvoiceProducts.Sum(i => i.Quantity * i.Price).ToString("C", new
            System.Globalization.CultureInfo("en-US")))
                </h5>
            }
            else
            {
                <p>No products found.</p>
            }

            @* Action Buttons *@

            <div class="mt-3">

                <button class="btn btn-success me-2" @onclick="DownloadInvoice">
                    Download Invoice
                </button>

                <button class="btn btn-custom me-2" @onclick="EditInvoice">
                    Edit
                </button>

                <button class="btn btn-danger me-2" @onclick="ShowConfirm">
                    Delete
                </button>

                <button class="btn btn-secondary" @onclick="BackToList">
                    Back
                </button>

            </div>

        </div>
    </div>
}

@code {
    [Parameter]
    public int id { get; set; }

    bool showConfirm { get; set; } = false;

    Invoice? invoice;
    bool isLoading = true;

    //Method to initialize the component and load the invoice details
    protected override async Task OnInitializedAsync()
    {
        if (!UserSession.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
        }

        try
        {
        invoice = await Context.Invoices
            .Include(i => i.Client)
            .Include(i => i.InvoiceProducts)
                .ThenInclude(ip => ip.Product)
            .FirstOrDefaultAsync(i => 
                i.InvoiceId == id &&
                i.UserId == UserSession.UserId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading invoice: {ex.Message}");
        }
          isLoading = false;
    }

    // Generate a simple text representation of the invoice and trigger a download
    async Task DownloadInvoice()
    {
        if (invoice == null)
            return;

        var content = new StringBuilder();

        content.AppendLine($"Invoice #{invoice.InvoiceId}");
        content.AppendLine();
        content.AppendLine($"Client: {invoice.Client?.ClientName}");
        content.AppendLine($"Invoice Date: {invoice.InvoiceDate:d}");
        content.AppendLine($"Due Date: {invoice.DueDate:d}");
        content.AppendLine($"Status: {(invoice.IsPaid ? "Paid" : "Unpaid")}");
        content.AppendLine();

        content.AppendLine("Products");
        content.AppendLine("----------------------------------");

        // List each product with quantity and price
        foreach (var item in invoice.InvoiceProducts)
        {
            content.AppendLine(
                $"Product {item.ProductId} | Qty: {item.Quantity} | Price: {item.Price:C}");
        }

        content.AppendLine();

        decimal total =
            invoice.InvoiceProducts.Sum(i => i.Quantity * i.Price);

        content.AppendLine($"Grand Total: {total:C}");

        var bytes = Encoding.UTF8.GetBytes(content.ToString());
        var base64 = Convert.ToBase64String(bytes);


        try
        {
            // Use JS interop to trigger the file download
            await JS.InvokeVoidAsync(
                "downloadFile",
                $"Invoice-{invoice.InvoiceId}.txt",
                base64);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error downloading invoice: {ex.Message}");
        }
    }

    // Navigate back to the invoice list
    private async Task BackToList()
    {
        await JS.InvokeVoidAsync("history.back");
    }

    void EditInvoice()
    {
        if (invoice != null)
        {
            Navigation.NavigateTo($"/invoices/edit/{invoice.InvoiceId}");
        }
    }

    // Method to show confirmation modal for deleting an invoice
    void ShowConfirm()
    {
        showConfirm = true;
    }

    // Method to cancel the delete action and hide the confirmation modal
    void CancelDelete()
    {
        showConfirm = false;
    }

    // Method to confirm deletion of an invoice, remove it from the database, and update the UI
    async Task ConfirmDelete()
    {
        if (invoice == null)
            return;
        try
        {
            Context.Invoices.Remove(invoice);
            await Context.SaveChangesAsync();

            Navigation.NavigateTo("/invoices?message=delete", true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting invoice: {ex.Message}");
        }
    }

}