@page "/edit-account"

@using System.Globalization;
@using Microsoft.AspNetCore.Identity;
@using Microsoft.EntityFrameworkCore;
@using InvoiceTracker
@rendermode InteractiveServer
@inject InvoiceTrackerContext Db
@inject NavigationManager Navigation
@inject UserSession UserSession

<PageTitle>Account Details</PageTitle>

<h2>Account Details</h2>

<div>
  @if (currentUser == null)
  {
    <p>Loading...</p>
  }
  else
  {
    <h3>@currentUser.CompanyName</h3>

    <p>
      <strong>Email:</strong>
      @currentUser.CompanyEmail
    </p>

    <p>
      <strong>Phone:</strong>
      @currentUser.CompanyPhone
    </p>

    <p>
      <strong>Address:</strong><br />
      @currentUser.CompanyAddress<br />
      @currentUser.CompanyCity, @currentUser.CompanyState
    </p>

    <p>
      <button class="btn btn-primary">
        Edit Account
      </button>
    </p>
  }
</div>


@code{
  private User? currentUser;

  protected override async Task OnInitializedAsync()
  {
    if (!UserSession.IsAuthenticated)
    {
      Navigation.NavigateTo("/login");
    }  
    await LoadUser();
  }

  private async Task LoadUser()
  {
    currentUser = await Db.Users
      .FirstOrDefaultAsync(u => u.UserId == UserSession.UserId);
  }
}