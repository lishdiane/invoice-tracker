@* Create Invoice Page *@
@page "/create-invoice"
@rendermode InteractiveServer

@inject InvoiceTrackerContext Context
@inject NavigationManager Navigation
@inject UserSession UserSession


<PageTitle>Create Invoice</PageTitle>

<div class="page-content create-form">
    <h1 class="pb-3">Create Invoice</h1>
    <EditForm EditContext="editContext" OnValidSubmit="SaveInvoice" FormName="create-invoice">
        <DataAnnotationsValidator />
        
        @* Client Selection *@
        <div class="mb-3">
            <div>
                <label for="client" class="form-label">Client</label>
    
                <InputSelect 
                    name="ClientId"
                    class="@validator.GetFieldCssClass(nameof(createInvoice.ClientId))" 
                    @bind-Value="selectedClientId"
                    @bind-Value:after="OnClientChanged"
                    @onblur="@(() => validator.ValidateField(nameof(createInvoice.ClientId)))">
                    
                    <option value="0">-- Select Client --</option>
                    @* Client Options *@
                    @foreach (var client in clients)
                    {
                        <option value="@client.ClientId">
                            @client.ClientName
                        </option>
                    }
                    <option value="-1">+ New Client</option>
                </InputSelect>
                <ValidationMessage For="@(() => createInvoice.ClientId)" />
            </div>
        </div>

        @* Product Selection *@
        <div class="mb-3 product-selection">
            <div>
                <label for="product" class="form-label">Products</label>
                @foreach (var line in createInvoice.Lines.Select((value, index) => new { value, index }))
                {
                    <div class="product-line">
                        <InputSelect class="form-control" @bind-Value="line.value.ProductId"
                                     @bind-Value:after="() => SetActiveLine(line.value)">
                            <option value="0">-- Select Product --</option>

                            @* Product Options *@
                            @foreach (var product in products)
                            {
                                <option value="@product.ProductId">
                                    @product.ProductName -
                                    @product.ProductPrice.ToString("C", new System.Globalization.CultureInfo("en-US"))
                                </option>
                            }
                        </InputSelect>
                        @* Quantity *@
                        <InputNumber 
                            class="form-control"
                            @bind-Value="line.value.Quantity" />
                        <a>
                            <button type="button" class="btn btn-custom btn-danger"
                                    @onclick="() => RemoveProduct(line.index)">
                                X
                            </button>
                        </a>
                    </div>
                }
                <a>
                    <button type="button" class="btn btn-success" @onclick="ShowProductModal">
                        New Product
                    </button>
                </a>
                <button type="button" class="btn btn-custom btn-primary" @onclick="AddProduct">Add Line
                </button>
            </div>
        </div>
        
        @* Invoice Date *@
        <div class="mb-3">
            <label class="form-label">Invoice Date</label>
            <InputDate class="@validator.GetFieldCssClass(nameof(createInvoice.InvoiceDate))"
                       @bind-Value="createInvoice.InvoiceDate"
                       @onblur="@(_ => validator.ValidateField(nameof(createInvoice.InvoiceDate)))" />
            <ValidationMessage For="@(() => createInvoice.InvoiceDate)" />
        </div>

        @* Due Date *@
        <div class="mb-3">
            <label class="form-label">Due Date</label>
            <InputDate class="@validator.GetFieldCssClass(nameof(createInvoice.DueDate))"
                       @bind-Value="createInvoice.DueDate"
                       @onblur="@(_ => validator.ValidateField(nameof(createInvoice.DueDate)))" />
            <ValidationMessage For="@(() => createInvoice.DueDate)" />
        </div>

        @* Invoice Total *@
        <div class="invoice-total">
            <p><strong>Invoice Total: </strong> @GetInvoiceTotal.ToString("C", new
                                                                System.Globalization.CultureInfo("en-US"))</p>
        </div>

        @* Action Buttons *@
        <div class="centered">
            <button type="submit" class="btn btn-success" disabled="@(!isFormValid)">
                Save Invoice
            </button>

            <button type="button" class="btn btn-custom ms-2" @onclick="Cancel">
                Cancel
            </button>
        </div>
        
        <ValidationSummary />
    </EditForm>

  @* Product Modal to create a new product *@
    @if (showProductModal)
    {
        <div class="modal-backdrop-custom">
            <div class="custom-modal">

                <h4>Add Product</h4>

                @* Display product creation error message *@
                @if (!string.IsNullOrWhiteSpace(productError))
                {
                    <div class="alert alert-danger">
                        @productError
                    </div>
                }

                @* Product Name *@
                <div class="mb-3">
                    <label>Product Name</label>

                    <InputText
                        class="form-control"
                        @bind-Value="newProduct.ProductName" />
                </div>

                @* Product Price *@
                <div class="mb-3">
                    <label>Price</label>

                    <InputNumber
                        class="form-control"
                        @bind-Value="newProduct.ProductPrice" />
                </div>

                @* Action Buttons *@
                <div class="modal-buttons">
                    <button
                        type="button"
                        class="btn btn-primary"
                        @onclick="SaveNewProduct"
                        disabled="@(!isProductFormValid)">
                        Save Product
                    </button>
                    <button
                        type="button"
                        class="btn btn-secondary"
                        @onclick="CloseProductModal">
                        Cancel
                    </button>
                    
                </div>
                
            </div>
        </div>
    }

    @* Client Modal to create a new client *@
    @if (showClientModal)
    {
        <div class="modal-backdrop-custom">
            <div class="custom-modal">

                <h4>Add Client</h4>

                @* Client Name *@
                <div class="mb-3">
                    <label>Client Name</label>
                    <InputText 
                        class="form-control"
                    @bind-Value="newClient.ClientName" />
                </div>

                @* Client Email *@
                <div class="mb-3">
                    <label>Email</label>
                    <InputText 
                        class="form-control"
                    @bind-Value="newClient.ClientEmail" />
                </div>

                @* Client Phone *@
                <div class="mb-3">
                    <label>Phone</label>
                    <InputText 
                        class="form-control"
                    @bind-Value="newClient.ClientPhone" />
                </div>

                <hr />

                @* Client Address *@
                <h6>Address</h6>

                <div class="mb-3">
                    <label>Street</label>
                    <InputText 
                        class="form-control"
                        @bind-Value="newClient.ClientAddress" />
                </div>

                <div class="row">
                    <div class="col">
                        <label>City</label>
                        <InputText 
                            class="form-control"
                            @bind-Value="newClient.ClientCity" />
                    </div>

                    <div class="col">
                        <label>State</label>
                        <InputText 
                            class="form-control"
                        @bind-Value="newClient.ClientState" />
                    </div>
                </div>

                @* Action Buttons *@
                <div class="modal-buttons mt-3">
                    <button type="button"
                            class="btn btn-primary"
                            @onclick="SaveNewClient"
                            disabled="@(!isClientFormValid)">
                        Save Client
                    </button>
                    <button type="button"
                            class="btn btn-secondary"
                            @onclick="CloseClientModal"
                            >
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {

    private List<Client> clients = new();
    private List<Product> products = new();
    private decimal selectedPrice;
    protected CreateInvoiceModel createInvoice = new();
    private CreateInvoiceLine? activeLine;
    private EditContext editContext;
    private FormValidationHelper validator;   
    private int? selectedClientId; 

    // Temporary models for new product and client creation in modals
    private Product newProduct = new()
    {
        ProductName = string.Empty
    };
    private Client newClient = new()
    {
        ClientName = "",
        ClientPhone = ""
    };

    // Required fields for validation
    private readonly string[] requiredFields = 
        [
            nameof(createInvoice.ClientId),
            nameof(createInvoice.InvoiceDate),
            nameof(createInvoice.DueDate)
        ];

    // Computed property to determine if the form is valid. 
    // It checks that there are no validation messages, at least one product line is added, 
    // and that all product lines have a selected product and quantity greater than zero.
    private bool isFormValid => 
        !editContext.GetValidationMessages().Any() &&
        createInvoice.Lines.Count > 0 &&
        createInvoice.Lines.All(line => line.ProductId > 0 && line.Quantity > 0);
    private bool isClientFormValid =>
        !string.IsNullOrWhiteSpace(newClient.ClientName) &&
        !string.IsNullOrWhiteSpace(newClient.ClientPhone) &&
        !string.IsNullOrWhiteSpace(newClient.ClientAddress) &&
        !string.IsNullOrWhiteSpace(newClient.ClientCity) &&
        !string.IsNullOrWhiteSpace(newClient.ClientState);
    private bool isProductFormValid =>
        !string.IsNullOrWhiteSpace(newProduct.ProductName) &&
        newProduct.ProductPrice > 0;

    private bool showProductModal;
    private bool showClientModal;
    private string productError = "";
    private string clientError = "";

    // On component initialization, check if the user is authenticated.
    // If not authenticated, redirect to the login page. If authenticated, load the user's clients
    protected override async Task OnInitializedAsync()
    {
        if (!UserSession.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
        }
        editContext = new EditContext(createInvoice);

        editContext.OnFieldChanged += (_, __) =>
        {
            InvokeAsync(StateHasChanged);
        };

        editContext.OnValidationStateChanged += (_, __) =>
        {
            InvokeAsync(StateHasChanged);
        };
        validator = new FormValidationHelper(editContext, requiredFields);
        createInvoice.Lines.Add(new CreateInvoiceLine());

        try
        {
            clients = await Context.Clients
                .AsNoTracking()
                .Where(client => client.UserId == UserSession.UserId)
                .ToListAsync();

            products = await Context.Products
                .AsNoTracking()
                .Where(product => product.UserId == UserSession.UserId)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading clients/products: {ex.Message}");
        }

        createInvoice.InvoiceDate = DateTime.UtcNow.Date;
        createInvoice.DueDate = DateTime.UtcNow.Date.AddDays(30);
    }

    // When the client selection changes, if the user selects the option to add a new client 
    // (value of -1), show the client creation modal
    private void OnClientChanged()
    {
        Console.WriteLine(selectedClientId);
        if (selectedClientId == -1)
        {
            showClientModal = true;
        } 
        else 
        {
          createInvoice.ClientId = selectedClientId.Value;
          editContext.NotifyFieldChanged(
              new FieldIdentifier(createInvoice, nameof(createInvoice.ClientId))
          );
      }
    }

    // Set the active line when a product is selected, so that if the user creates a new product, 
    // it can be automatically assigned to the active line
    private void SetActiveLine(CreateInvoiceLine line)
    {
        activeLine = (line);
    }

    // Save the invoice to the database. It first creates the invoice record, 
    // then creates the associated invoice line records, and finally navigates back to the invoice list page.
    async Task SaveInvoice()
    {
        try {
        // Assign values from the createInvoice model to the new Invoice entity
            var invoice = new Invoice
            {
                UserId = UserSession.UserId,
                ClientId = createInvoice.ClientId,
                InvoiceDate = DateTime.SpecifyKind(
                    createInvoice.InvoiceDate,
                    DateTimeKind.Utc),
                DueDate = DateTime.SpecifyKind(
                    createInvoice.DueDate,
                    DateTimeKind.Utc)
            };

            Context.Invoices.Add(invoice);
            await Context.SaveChangesAsync();
      
        //Create invoice line records for each line in the createInvoice model
            foreach (var invoiceLine in createInvoice.Lines)
            {
                var selectedProduct =
                    products.FirstOrDefault(
                        p => p.ProductId == invoiceLine.ProductId);

                var invoiceProduct = new InvoiceProduct
                {
                    InvoiceId = invoice.InvoiceId,
                    ProductId = invoiceLine.ProductId,
                    Quantity = invoiceLine.Quantity,
                    Price = selectedProduct?.ProductPrice ?? 0
                };

                Context.InvoiceProducts.Add(invoiceProduct);
            }
            await Context.SaveChangesAsync();
        Navigation.NavigateTo("/invoices?message=create");

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving invoice: {ex.Message}");
        }
    }

    // Cancel invoice creation and navigate back to the invoice list page
    void Cancel()
    {
        Navigation.NavigateTo("/invoices");
    }

    // Add a new product line to the invoice
    private void AddProduct()
    {
        createInvoice.Lines.Add(new CreateInvoiceLine());

        editContext.NotifyFieldChanged(
            new FieldIdentifier(createInvoice, nameof(createInvoice.Lines)));
    }

    // Remove a product line from the invoice.
    private void RemoveProduct(int index)
    {
        if (createInvoice.Lines.Count <= 1)
        {
            return;
        }
        createInvoice.Lines.RemoveAt(index);

        editContext.NotifyFieldChanged(
            new FieldIdentifier(createInvoice, nameof(createInvoice.Lines)));
    }

    // Show the product creation modal.
    private void ShowProductModal()
    {
        newProduct = new Product()
        {
            ProductName = string.Empty
        };
        productError = "";
        showProductModal = true;
    }

    // Show the client creation modal.
    private void ShowClientModal()
    {
        newClient = new Client()
        {
            ClientName = string.Empty,
            ClientPhone = string.Empty,
            ClientEmail = string.Empty,
            ClientAddress = string.Empty,
            ClientCity = string.Empty,
            ClientState = string.Empty
        };
        clientError = "";
        showClientModal = true;
    }

    // Close the client creation modal
    private void CloseClientModal()
    {
        showClientModal = false;
    }

    // Close the product creation modal
    private void CloseProductModal()
    {
        showProductModal = false;
    }

    // Save a new product to the database. It validates the product name and price.
    private async Task SaveNewProduct()
    {
        productError = "";

        if (string.IsNullOrWhiteSpace(newProduct.ProductName))
        {
            productError = "Product name is required.";
            return;
        }

        if (newProduct.ProductPrice <= 0)
        {
            productError = "Price must be greater than zero.";
            return;
        }

        newProduct.UserId = UserSession.UserId;

        try {
            Context.Products.Add(newProduct);
            await Context.SaveChangesAsync();

            products.Add(newProduct);

            if (activeLine is not null)
            {
                activeLine.ProductId = newProduct.ProductId;
            }
            showProductModal = false;
        }
        catch (Exception ex)
        {
            productError = "Error saving product. Please try again.";
            Console.WriteLine($"Error saving product: {ex.Message}");
        }
    }

    // Save a new client to the database. It validates the client name and email.
    private async Task SaveNewClient()
    {
        clientError = "";
        newClient.UserId = UserSession.UserId;

        try {
        Context.Clients.Add(newClient);
        await Context.SaveChangesAsync();

        clients.Add(newClient);
        createInvoice.ClientId = newClient.ClientId;
        selectedClientId = newClient.ClientId;

        editContext.NotifyFieldChanged(
            new FieldIdentifier(createInvoice, nameof(createInvoice.ClientId))
        );
        editContext.NotifyValidationStateChanged();

        showClientModal = false;
        }
        catch (Exception ex)
        {
            clientError = "Error saving client. Please try again.";
            Console.WriteLine($"Error saving client: {ex.Message}");
        }
    }

    // Calculate the total for a given invoice line by multiplying the quantity by the product price.
    private decimal GetLineTotal(CreateInvoiceLine line)
    {
        var product = products.FirstOrDefault(p => p.ProductId == line.ProductId);
        return line.Quantity * (product?.ProductPrice ?? 0);
    }

    // Calculate the total for the entire invoice by summing the totals of each line.
    private decimal GetInvoiceTotal =>
        createInvoice.Lines.Sum(line =>
        {
            var product = products.FirstOrDefault(p => p.ProductId == line.ProductId);
            return line.Quantity * (product?.ProductPrice ?? 0);
        });

}