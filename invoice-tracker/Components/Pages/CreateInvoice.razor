@page "/invoices/create"
@rendermode InteractiveServer

@inject InvoiceTrackerContext Context
@inject NavigationManager Navigation
@inject UserSession UserSession

<h3 class="centered">Create Invoice</h3>

<div class="page-content create-form">
    <EditForm Model="invoice" OnValidSubmit="SaveInvoice" FormName="create-invoice">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="mb-3">
            <label class="form-label">Client</label>

            <InputSelect class="form-control" @bind-Value="invoice.ClientId">
                <option value="">-- Select Client --</option>

                @foreach (var client in clients)
                {
                    <option value="@client.ClientId">
                        @client.ClientName
                    </option>
                }
            </InputSelect>
        </div>

        <div class="mb-3 product-selection">
            <div>
                <label for="product" class="form-label">Product</label>

                <InputSelect id="product" class="form-control" @bind-Value="invoiceProduct.ProductId"
                             @bind-Value:after="OnProductSelected">
                    <option value="">-- Select Product --</option>

                    @foreach (var product in products)
                    {
                        <option value="@product.ProductId">
                            $@product.ProductPrice @product.ProductName
                        </option>
                    }
                </InputSelect>
            </div>
            <div>
                <label for="quantity" class="form-label">Quantity</label>
                <input id="quantity" class="form-control" type="number" @bind=invoiceProduct.Quantity />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Invoice Date</label>
            <InputDate class="form-control" @bind-Value="invoice.InvoiceDate" />
        </div>

        <div class="mb-3">
            <label class="form-label">Due Date</label>
            <InputDate class="form-control" @bind-Value="invoice.DueDate" />
        </div>
        <div class="centered">
            <button type="submit" class="btn btn-custom btn-primary">
                Save Invoice
            </button>
        </div>
    </EditForm>
</div>

@code {

    Invoice invoice = new();
    InvoiceProduct invoiceProduct = new() { Quantity = 1 };
    List<Client> clients = new();
    List<Product> products = new();

    protected override async Task OnInitializedAsync()
    {
        if (!UserSession.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
        }

        clients = await Context.Clients
            .AsNoTracking()
            .Where(client => client.UserId == UserSession.UserId)
            .ToListAsync();

        products = await Context.Products
            .AsNoTracking()
            .Where(product => product.UserId == UserSession.UserId)
            .ToListAsync();

        invoice.UserId = UserSession.UserId;

        invoice.InvoiceDate = DateTime.UtcNow.Date;
        invoice.DueDate = DateTime.UtcNow.Date.AddDays(30);
    }

    void OnProductSelected()
    {
        var selected = products.FirstOrDefault(p => p.ProductId == invoiceProduct.ProductId);
        if (selected != null)
        {
            invoiceProduct.Price = selected.ProductPrice;
        }
    }

    async Task SaveInvoice()
    {
        if (invoice.ClientId <= 0)
            return;

        invoice.InvoiceDate = DateTime.SpecifyKind(invoice.InvoiceDate, DateTimeKind.Utc);
        invoice.DueDate = DateTime.SpecifyKind(invoice.DueDate, DateTimeKind.Utc);

        Context.Invoices.Add(invoice);
        await Context.SaveChangesAsync();

        invoiceProduct.InvoiceId = invoice.InvoiceId;
        Context.InvoiceProducts.Add(invoiceProduct);
        await Context.SaveChangesAsync();

        Navigation.NavigateTo("/invoices");
    }
}