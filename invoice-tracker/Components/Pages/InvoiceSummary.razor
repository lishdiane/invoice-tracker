@page "/invoice-summary"

@using Microsoft.EntityFrameworkCore

@inject InvoiceTrackerContext Context
@inject UserSession UserSession
@inject NavigationManager Navigation

<h3>Invoice Summary</h3>

<div class="row g-3">

    <div class="col-12 col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body text-center">
                <h5>Total Invoices</h5>
                <h2>@totalInvoices</h2>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body text-center">
                <h5>Paid</h5>
                <h2>@paidInvoices</h2>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-lg-3">
        <div class="card">
            <div class="card-body text-center">
                <h5>Unpaid</h5>
                <h2>@unpaidInvoices</h2>
            </div>
        </div>
    </div>

</div>

<hr />

<h4>Invoices</h4>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Invoice ID</th>
                <th>Client</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var invoice in invoices)
            {
                <tr>
                    <td>@invoice.InvoiceId</td>
                    <td>@invoice.Client?.ClientName</td>
                    <td>@(invoice.IsPaid ? "Paid" : "Unpaid")</td>
                    <td class="text-end">
                        <a class="btn btn-info btn-sm" href="/invoices/view/@invoice.InvoiceId">
                            View
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {

    int totalInvoices;
    int paidInvoices;
    int unpaidInvoices;

    List<Invoice> invoices = new();

    protected override async Task OnInitializedAsync()
    {
        // Redirect to login if not authenticated
        if (!UserSession.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        totalInvoices =
            await Context.Invoices.CountAsync();

        paidInvoices =
            await Context.Invoices.CountAsync(i => i.IsPaid);

        unpaidInvoices =
            await Context.Invoices.CountAsync(i => !i.IsPaid);

        invoices = await Context.Invoices
            .Include(i => i.Client)
            .ToListAsync();
    }
}