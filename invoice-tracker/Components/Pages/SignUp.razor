@page "/signup"

@using Microsoft.AspNetCore.Identity;
@using Microsoft.EntityFrameworkCore;
@using InvoiceTracker
@inject InvoiceTrackerContext Db
@inject NavigationManager Navigation

<PageTitle>Create Account</PageTitle>

<h1>Create Account</h1>

<EditForm Model="@registerUser" OnValidSubmit="HandleSignUp" FormName="SignUpForm" method="post">
  <DataAnnotationsValidator />
  <ValidationSummary />

  @if (!string.IsNullOrEmpty(errorMessage))
  {
    <div class="alert alert-danger">
      @errorMessage
    </div>
  }

  <fieldset>
    <legend>Account Information</legend>
    <div class="form-group">
      <label for="username">Username</label>
      <InputText id="username" class="form-control" @bind-Value="registerUser.Username" />
      <ValidationMessage For="@(() => registerUser.Username)" />
    </div>
    <div class="form-group">
      <label for="password">Password</label>
      <InputText id="password" type="password" class="form-control" @bind-Value="registerUser.Password" />
      <ValidationMessage For="@(() => registerUser.Password)" />
    </div>
    <div class="form-group">
      <label for="confirmPassword">Confirm Password</label>
      <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="registerUser.ConfirmPassword" />
    </div>
  </fieldset>

  <fieldset>
    <legend>Company Information</legend>
    <div class="form-group">
      <label for="companyName">Company Name</label>
      <InputText id="companyName" class="form-control" @bind-Value="registerUser.CompanyName" />
      <ValidationMessage For="@(() => registerUser.CompanyName)" />
    </div>
    <div class="form-group">
      <label for="companyEmail">Company Email</label>
      <InputText id="companyEmail" class="form-control" @bind-Value="registerUser.CompanyEmail" />
      <ValidationMessage For="@(() => registerUser.CompanyEmail)" />
    </div>

    <div class="form-group">
      <label for="companyPhone">Company Phone</label>
      <InputText id="companyPhone" class="form-control" @bind-Value="registerUser.CompanyPhone" />
      <ValidationMessage For="@(() => registerUser.CompanyPhone)" />
    </div>
  </fieldset>

  <fieldset>
    <legend>Company Address</legend>

    <div class="form-group">
      <label for="companyAddress">Street Address</label>
      <InputText id="companyAddress" class="form-control" @bind-Value="registerUser.CompanyAddress" />
      <ValidationMessage For="@(() => registerUser.CompanyAddress)" />
    </div>

    <div class="form-group">
      <label for="companyCity">City</label>
      <InputText id="companyCity" class="form-control" @bind-Value="registerUser.CompanyCity" />
      <ValidationMessage For="@(() => registerUser.CompanyCity)" />
    </div>

    <div class="form-group">
      <label for="companyState">State</label>
      <InputText id="companyState" class="form-control" @bind-Value="registerUser.CompanyState" />
      <ValidationMessage For="@(() => registerUser.CompanyState)" />
    </div>
  </fieldset>

  <button type="submit" class="btn btn-primary" disabled="@isError">
    Create Account
  </button>
</EditForm>

@code {

  private bool isError = false;
  private RegisterUser registerUser = new();
  private EditContext editContext;
  private readonly PasswordHasher<User> _passwordHasher = new();
  private string errorMessage = "";

  protected override void OnInitialized()
  {
    editContext = new EditContext(registerUser);
    editContext.OnFieldChanged += (_, __) => ValidateForm();
    registerUser.Password = "";
    registerUser.ConfirmPassword = "";
  }
  protected void ShowError() => isError = true;
  private async Task HandleSignUp()
  {
    errorMessage = "";

    var existingUser = await Db.Users
        .FirstOrDefaultAsync(
            u => u.Username == registerUser.Username);

    if (existingUser != null)
    {
      errorMessage = "Username already exists.";
      return;
    }

    var user = new User
    {
      Username = registerUser.Username,
      Password = string.Empty, // not yet hashed
      CompanyName = registerUser.CompanyName,
      CompanyEmail = registerUser.CompanyEmail,
      CompanyAddress = registerUser.CompanyAddress,
      CompanyCity = registerUser.CompanyCity,
      CompanyState = registerUser.CompanyState,
      CompanyPhone = registerUser.CompanyPhone
    };

    user.Password =
      _passwordHasher.HashPassword(
        user,
        registerUser.Password);

    Db.Users.Add(user);

    await Db.SaveChangesAsync();

    Navigation.NavigateTo("/");
  }
}