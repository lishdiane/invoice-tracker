@page "/signup"
@layout LoginLayout

@using System.Globalization;
@using Microsoft.AspNetCore.Identity;
@using Microsoft.EntityFrameworkCore;
@using InvoiceTracker
@rendermode InteractiveServer
@inject InvoiceTrackerContext Db
@inject NavigationManager Navigation
@inject UserSession UserSession

<PageTitle>Create Account</PageTitle>

<div class="profile-card">
  <h1>Create Account</h1>

  <EditForm EditContext="editContext" OnValidSubmit="HandleSignUp" FormName="SignUpForm">
    <DataAnnotationsValidator />

    @if (!string.IsNullOrEmpty(errorMessage))
    {
      <div class="alert alert-danger">
        @errorMessage
      </div>
    }

    <fieldset>
      <legend>Account Information</legend>
      <div class="form-group mb-3">
        <label for="username">Username</label>
        <InputText id="username" class="@validator.GetFieldCssClass(nameof(registerUser.Username))"
                   @bind-Value="registerUser.Username"
                   @onblur="@(_ => validator.ValidateField(nameof(registerUser.Username)))" />
        <ValidationMessage For="@(() => registerUser.Username)" />
      </div>
      <div class="form-group mb-3">
        <label for="password">Password</label>
        <InputText id="password" type="password" class="@validator.GetFieldCssClass(nameof(registerUser.Password))"
                   @bind-Value="registerUser.Password"
                   @onblur="@(_ => validator.ValidateField(nameof(registerUser.Password)))" />
        <ValidationMessage For="@(() => registerUser.Password)" />
      </div>
      <div class="form-group mb-3">
        <label for="confirmPassword">Confirm Password</label>
        <InputText id="confirmPassword" type="password"
                   class="@validator.GetFieldCssClass(nameof(registerUser.ConfirmPassword))"
                   @bind-Value="registerUser.ConfirmPassword"
                   @onblur="@(_ => validator.ValidateField(nameof(registerUser.ConfirmPassword)))" />
        <ValidationMessage For="@(() => registerUser.ConfirmPassword)" />
      </div>
    </fieldset>

    <fieldset>
      <legend>Company Information</legend>
      <div class="form-group mb-3">
        <label for="companyName">Company Name</label>
        <InputText id="companyName" class="@validator.GetFieldCssClass(nameof(registerUser.CompanyName))"
                   @bind-Value="registerUser.CompanyName"
                   @onblur="@(_ => validator.ValidateField(nameof(registerUser.CompanyName)))" />
        <ValidationMessage For="@(() => registerUser.CompanyName)" />
      </div>
      <div class="form-group mb-3">
        <label for="companyEmail">Company Email</label>
        <InputText id="companyEmail" class="@validator.GetFieldCssClass(nameof(registerUser.CompanyEmail))"
                   @bind-Value="registerUser.CompanyEmail"
                   @onblur="@(_ => validator.ValidateField(nameof(registerUser.CompanyEmail)))" />
        <ValidationMessage For="@(() => registerUser.CompanyEmail)" />
      </div>

      <div class="form-group mb-3">
        <label for="companyPhone">Company Phone</label>
        <InputText id="companyPhone" class="@validator.GetFieldCssClass(nameof(registerUser.CompanyPhone))"
                   @bind-Value="registerUser.CompanyPhone"
                   @onblur="@(_ => validator.ValidateField(nameof(registerUser.CompanyPhone)))" />
        <ValidationMessage For="@(() => registerUser.CompanyPhone)" />
      </div>
    </fieldset>

    <fieldset>
      <legend>Company Address</legend>

      <div class="form-group mb-3">
        <label for="companyAddress">Street Address</label>
        <InputText id="companyAddress" class="@validator.GetFieldCssClass(nameof(registerUser.CompanyAddress))"
                   @bind-Value="registerUser.CompanyAddress"
                   @onblur="@(_ => validator.ValidateField(nameof(registerUser.CompanyAddress)))" />
        <ValidationMessage For="@(() => registerUser.CompanyAddress)" />
      </div>

      <div class="form-group mb-3">
        <label for="companyCity">City</label>
        <InputText id="companyCity" class="@validator.GetFieldCssClass(nameof(registerUser.CompanyCity))"
                   @bind-Value="registerUser.CompanyCity"
                   @onblur="@(_ => validator.ValidateField(nameof(registerUser.CompanyCity)))" />
        <ValidationMessage For="@(() => registerUser.CompanyCity)" />
      </div>

      <div class="form-group mb-3">
        <label for="companyState">State</label>
        <InputText id="companyState" class="@validator.GetFieldCssClass(nameof(registerUser.CompanyState))"
                   @bind-Value="registerUser.CompanyState"
                   @onblur="@(_ => validator.ValidateField(nameof(registerUser.CompanyState)))" />
        <ValidationMessage For="@(() => registerUser.CompanyState)" />
      </div>
    </fieldset>

    <button type="submit" class="btn btn-primary btn-centered" disabled="@(!isFormValid)">
      Create Account
    </button>
    <ValidationSummary />
  </EditForm>
</div>

@code {

  private HashSet<string> validatedFields = new();
  private bool isFormValid => validator?.IsFormValid(requiredFields) ?? false;
  private RegisterUser registerUser = new();
  private FormValidationHelper validator;
  private EditContext editContext;
  private readonly PasswordHasher<User> _passwordHasher = new();
  private string errorMessage = "";
  private readonly string[] requiredFields =
  [
    nameof(registerUser.Username),
    nameof(registerUser.Password),
    nameof(registerUser.ConfirmPassword),
    nameof(registerUser.CompanyName),
    nameof(registerUser.CompanyEmail),
    nameof(registerUser.CompanyAddress),
    nameof(registerUser.CompanyCity),
    nameof(registerUser.CompanyState),
    nameof(registerUser.CompanyPhone)
  ];

  protected override void OnInitialized()
  {
    if (UserSession.IsAuthenticated)
    {
      Navigation.NavigateTo("/");
      errorMessage = "You are already signed in.";
    }
    editContext = new EditContext(registerUser);
    validator = new FormValidationHelper(editContext, requiredFields);
  }
  private async Task HandleSignUp()
  {
    errorMessage = "";
    try
    {
      @* Code below requires DB connection *@
      var existingUser = await Db.Users
          .FirstOrDefaultAsync(
              u => u.Username == registerUser.Username);

      if (existingUser != null)
      {
        errorMessage = "Username already exists.";
        return;
      }

      var user = new User
      {
        Username = registerUser.Username,
        Password = string.Empty, // not yet hashed
        CompanyName = registerUser.CompanyName,
        CompanyEmail = registerUser.CompanyEmail,
        CompanyAddress = registerUser.CompanyAddress,
        CompanyCity = registerUser.CompanyCity,
        CompanyState = registerUser.CompanyState,
        CompanyPhone = registerUser.CompanyPhone
      };

      user.Password =
        _passwordHasher.HashPassword(
          user,
          registerUser.Password);

      @* Local Testing only *@
      @* Console.WriteLine("=== NEW USER ===");
      Console.WriteLine($"Username: {user.Username}");
      Console.WriteLine($"Company: {user.CompanyName}");
      Console.WriteLine($"Email: {user.CompanyEmail}");
      Console.WriteLine($"Password Hash: {user.Password}");
      errorMessage = "Form submitted successfully!"; *@

      @* Code below requires DB connection *@
      Db.Users.Add(user);
      await Db.SaveChangesAsync();

      Navigation.NavigateTo("/");
    }
    catch (Exception ex)
    {
      errorMessage = $"An error occurred. Please try again.";
      Console.WriteLine($"Signup error: {ex.Message}");
    }
  }
}