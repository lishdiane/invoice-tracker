@page "/"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject UserSession UserSession

@* @attribute [AllowAnonymous] *@



<PageTitle>Home</PageTitle>
<div class="hero-section">
    <h1>Welcome to Invoice Tracker</h1>

    <p class="hero-text">
        Simplify invoice management, track client payments,
        and keep your billing records organized in one place.
    </p>

    <div class="action-buttons">
        <a href="/invoices" class="btn btn-primary">
            View Invoices
        </a>

        <a href="/invoices/create" class="btn btn-success">
            Create Invoice
        </a>
    </div>
</div>

<div class="feature-grid">

    <div class="feature-card">
        <h3>Create Invoices</h3>
        <p>
            Generate professional invoices quickly and efficiently.
        </p>
    </div>

    <div class="feature-card">
        <h3>Manage Records</h3>
        <p>
            View, edit, and organize invoice information with ease.
        </p>
    </div>

    <div class="feature-card">
        <h3>Invoice Summary</h3>
        <p>
            Access financial summaries and invoice statistics.
        </p>
    </div>

</div>

<div class="getting-started">
    <h2>Getting Started</h2>

    <ol>
        <li>Create an account or login.</li>
        <li>Create a new invoice.</li>
        <li>Manage and update invoices.</li>
        <li>Review invoice summaries and reports.</li>
    </ol>
</div>


<button class="btn btn-primary" @onclick="NavigateToLogin">Go to Login</button>
<button class="btn btn-outline-danger" @onclick="Logout">Logout</button>

@code {
    
    // Method to navigate to the login page
    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    // Logout method to clear session and redirect to login page
    private void Logout()
    {
        UserSession.IsAuthenticated = false;
        UserSession.UserId = 0;
        UserSession.Username = string.Empty;
        Navigation.NavigateTo("/login?message=logout");

    }

    @* protected override void OnInitialized()
    {
        if (!UserSession.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
        }
    } *@
}