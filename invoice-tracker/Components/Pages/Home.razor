@page "/"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject UserSession UserSession

@* @attribute [AllowAnonymous] *@



<PageTitle>Home</PageTitle>
@* Hero Section *@
<div class="hero-section">
    <h1>Welcome to Invoice Tracker</h1>

    <p class="hero-text">
        Simplify invoice management, track client payments,
        and keep your billing records organized in one place.
    </p>

    @* Action Buttons *@
    <div class="action-buttons">
        <a href="/invoices" class="btn btn-dark">
            View Invoices
        </a>

        <a href="/create-invoice" class="btn btn-home">
            Create Invoice
        </a>
    </div>
</div>

@* Features Section *@
<div class="feature-grid">

    <div class="feature-card">
        <h3>Create Invoices</h3>
        <p>
            Generate professional invoices quickly and efficiently.
        </p>
    </div>

    <div class="feature-card">
        <h3>Manage Records</h3>
        <p>
            View, edit, and organize invoice information with ease.
        </p>
    </div>

    <div class="feature-card">
        <h3>Invoice Summary</h3>
        <p>
            Access financial summaries and invoice statistics.
        </p>
    </div>

</div>

@* Getting Started section with links to other pages *@
<div class="getting-started">
    <h3>Getting Started</h3>
    <ul class="getting-started-list">
        <li>
            <a href="/create-invoice">
                Create a new invoice 
            </a>
        </li>

        <li>
            <a href="/invoices">
                View and manage invoices 
            </a>
        </li>

        <li>
            <a href="/dashboard">
                Review invoice summaries 
            </a>
        </li>
    </ul>
</div>

@code {
    
    // Method to navigate to the login page
    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    // Logout method to clear session and redirect to login page
    private void Logout()
    {
        UserSession.IsAuthenticated = false;
        UserSession.UserId = 0;
        UserSession.Username = string.Empty;
        Navigation.NavigateTo("/login?message=logout");
    }
}
