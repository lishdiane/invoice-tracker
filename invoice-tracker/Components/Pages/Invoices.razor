@page "/invoices"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject InvoiceTrackerContext Context
@inject NavigationManager Navigation

<h3>Invoices</h3>

@if (invoices == null)
{
    <p>Loading...</p>
}
else
{
    @if (showConfirm)
    {
        <div class="alert alert-warning d-flex justify-content-between align-items-center">
            <span>Are you sure you want to delete this invoice?</span>

            <div>
                <button class="btn btn-danger btn-sm me-2" @onclick="ConfirmDelete">
                    Yes
                </button>

                <button class="btn btn-secondary btn-sm" @onclick="CancelDelete">
                    No
                </button>
            </div>
        </div>
    }

    <table class="table table-striped">

        <thead>
            <tr>
                <th>ID</th>
                <th>Client</th>
                <th>Date</th>
                <th>Due</th>
                <th>Status</th>
                <th>Total</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var invoice in invoices)
            {
                <tr>
                    <td>@invoice.InvoiceId</td>
                    <td>@invoice.Client.ClientName</td>
                    <td>@invoice.InvoiceDate.ToShortDateString()</td>
                    <td>@invoice.DueDate.ToShortDateString()</td>

                    <td>
                        @if (invoice.IsPaid)
                        {
                            <span class="badge bg-success">Paid</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Unpaid</span>
                        }
                    </td>

                    <td>
                        @GetTotal(invoice).ToString("C")
                    </td>

                    <td>
                        <button type="button" class="btn btn-sm btn-warning" @onclick="() => EditInvoice(invoice.InvoiceId)">
                            Edit
                        </button>

                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => ShowConfirm(invoice.InvoiceId)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>

    </table>
}

@code {

    List<Invoice>? invoices;

    int? deleteId;

    bool showConfirm = false;

    protected override async Task OnInitializedAsync()
    {
        invoices = await Context.Invoices
            .Include(i => i.Client)
            .Include(i => i.InvoiceProducts)
            .ToListAsync();
    }

    decimal GetTotal(Invoice invoice)
    {
        return invoice.InvoiceProducts.Sum(p => p.Quantity * p.Price);
    }

    void EditInvoice(int id)
    {
        Navigation.NavigateTo($"/invoices/edit/{id}");
    }

    void ShowConfirm(int id)
    {
        deleteId = id;
        showConfirm = true;
    }

    void CancelDelete()
    {
        deleteId = null;
        showConfirm = false;
    }

    async Task ConfirmDelete()
    {
        if (deleteId == null)
            return;

        var invoice = await Context.Invoices.FindAsync(deleteId.Value);

        if (invoice != null)
        {
            Context.Invoices.Remove(invoice);
            await Context.SaveChangesAsync();

            invoices?.RemoveAll(i => i.InvoiceId == deleteId.Value);
        }

        deleteId = null;
        showConfirm = false;
    }
}