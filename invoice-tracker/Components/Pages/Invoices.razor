@page "/invoices"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject InvoiceTrackerContext Context
@inject NavigationManager Navigation
@inject UserSession UserSession

<PageTitle>Invoices</PageTitle>


<h1>Invoices</h1>

@* Confirmation Message after invoice deletion *@
    @if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">
        @successMessage
    </div>
}

@if (isLoading)
{
    <p>Loading...</p>
}
else if (invoices == null)
{
    <div class="alert alert-danger">
        No Invoices Found.
    </div>
}
else
{
    @* Confirmation Modal for the delete invoice action *@
    @if (showConfirm)
    {
        <div class="modal-backdrop-custom">
            <div class="custom-modal">
                @if (!showSuccess)
                {
                    <div class="alert alert-warning d-flex justify-content-between align-items-center">
                        <span>Are you sure you want to delete this invoice?</span>

                        <div class="d-flex gap-2">
                            <button class="btn btn-danger btn-sm" @onclick="ConfirmDelete">
                                Yes
                            </button>

                            <button class="btn btn-secondary btn-sm" @onclick="CancelDelete">
                                No
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-success">
                        @successMessage
                    </div>
                }
            </div>
        </div>
    }

    @* Filter Section *@
    <div class="filter-section page-content filter-box">
        <div class="filters mb-3 d-flex flex-wrap gap-2 centered">

            @* Search Filter *@
            <label for="search">Search by client name</label>
            <input type="text" id="search" class="form-control form-control-sm medium-form"
                   placeholder="Search by client name..." @bind="searchTerm" @bind:event="oninput" />

            @* Status Filter *@
            <label for="status">Status</label>
            <select id="status" class="form-select form-select-sm short-form" @bind="statusFilter">
                <option value="">All Statuses</option>
                <option value="paid">Paid</option>
                <option value="unpaid">Unpaid</option>
            </select>

            @* Date Filters *@
            <div class=" d-flex flex-wrap gap-2">
                <div class="date-group">
                    <label for="fromDate">From:</label>
                    <input id="fromDate" type="date" class="form-control form-control-sm short-form" @bind="fromDate" />
                </div>
                <div class="date-group">
                    <label for="toDate">To:</label>
                    <input id="toDate" type="date" class="form-control form-control-sm short-form" @bind="toDate" />
                </div>
            </div>
        </div>
        @* Action Buttons *@
        <div class="d-flex gap-2 mb-3 centered">
            <button class="btn btn-custom btn-primary btn-sm" @onclick="ApplyFilters">
                Apply Filters
            </button>
            <button class="btn btn-custom btn-secondary btn-sm" @onclick="ClearFilters">
                Clear Filters
            </button>
        </div>
    </div>

    @* RESPONSIVE TABLE WRAPPER *@
    <div class="table-responsive">
        <div class="page-content">
            <table class="table align-middle custom-table">
                @* Table Header *@
                <thead>
                    <tr>
                        <th>ID</th>

                        <th>Client
                            <div class="dropdown d-inline">
                                @* Client Sort Options *@
                                <button class="btn p-0" data-bs-toggle="dropdown">
                                    ⇅
                                </button>
                                <ul class="dropdown-menu">
                                    <li>
                                        <button class="dropdown-item" @onclick='() => SortBy("client-asc")'>
                                            A-Z
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" @onclick='() => SortBy("client-desc")'>
                                            Z-A
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </th>

                        <th>Date
                            <div class="dropdown d-inline">
                                @* Date Sort Options *@
                                <button class="btn p-0" data-bs-toggle="dropdown">
                                    ⇅
                                </button>
                                <ul class="dropdown-menu">
                                    <li>
                                        <button class="dropdown-item" @onclick='() => SortBy("date-newest")'>
                                            Newest First
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" @onclick='() => SortBy("date-oldest")'>
                                            Oldest First
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </th>

                        <th>Due
                            <div class="dropdown d-inline">
                                @* Due Date Sort Options *@
                                <button class="btn p-0" data-bs-toggle="dropdown">
                                    ⇅
                                </button>
                                <ul class="dropdown-menu">
                                    <li>
                                        <button class="dropdown-item" @onclick='() => SortBy("date-newest")'>
                                            Newest First
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" @onclick='() => SortBy("date-oldest")'>
                                            Oldest First
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </th>

                        <th>Status</th>

                        <th>Total
                            <div class="dropdown d-inline">
                                @* Total Sort Options *@
                                <button class="btn p-0" data-bs-toggle="dropdown">
                                    ⇅
                                </button>
                                <ul class="dropdown-menu">
                                    <li>
                                        <button class="dropdown-item" @onclick='() => SortBy("total-high")'>
                                            High to Low
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item" @onclick='() => SortBy("total-low")'>
                                            Low to High
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </th>

                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @* Invoice Rows *@
                    @foreach (var invoice in invoices)
                    {
                        <tr>
                            <td>@invoice.InvoiceId</td>
                            <td><a href="/invoices/view/@invoice.InvoiceId" class="black-link">@invoice.Client.ClientName</a>
                            </td>
                            <td>@invoice.InvoiceDate.ToShortDateString()</td>
                            <td>@invoice.DueDate.ToShortDateString()</td>

                            <td>
                                @if (invoice.IsPaid)
                                {
                                    <span class="badge badge-green">Paid</span>
                                }
                                else
                                {
                                    <span class="badge badge-red">Unpaid</span>
                                }
                            </td>

                            <td>
                                @GetTotal(invoice).ToString("C")
                            </td>

                            <td>
                                @* Better mobile button layout *@
                                <div class="d-flex flex-wrap gap-1">
                                    <button type="button" class="btn btn-custom btn-sm"
                                            @onclick="() => EditInvoice(invoice.InvoiceId)">
                                        Edit
                                    </button>

                                    <button type="button" class="btn btn-custom btn-sm"
                                            @onclick="() => ShowConfirm(invoice.InvoiceId)">
                                        Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>

    @* Invoice Cards *@
    <div class="invoice-cards page-content">
        @foreach (var invoice in invoices)
        {
            <div class="invoice-card">
                <div class="invoice-header">
                    <div>
                        <span class="invoice-number">#@invoice.InvoiceId</span>
                        <a href="/invoices/view/@invoice.InvoiceId"> @invoice.Client.ClientName</a>
                    </div>
                    <span class="invoice-status @(invoice.IsPaid ? "paid" : "unpaid")">
                        @(invoice.IsPaid ? "Paid" : "Unpaid")
                    </span>
                </div>

                <div class="invoice-body">
                    <div>Date: <span>@invoice.InvoiceDate.ToShortDateString()</span></div>
                    <div>Due: <span>@invoice.DueDate.ToShortDateString()</span></div>
                    <div>Total: <span>@GetTotal(invoice).ToString("C")</span></div>
                </div>
                <div class="line"></div>
                <div class="invoice-actions">
                    <button class="btn btn-custom" @onclick="() => EditInvoice(invoice.InvoiceId)">Edit</button>
                    <button class="btn btn-custom" @onclick="() => ShowConfirm(invoice.InvoiceId)">Delete</button>
                </div>
            </div>
        }
    </div>
}



@code {

    List<Invoice>? invoices;

    int? deleteId;
    bool showConfirm = false;

    bool showSuccess = false;
    string successMessage = "";
    bool isLoading = true;

    // Method to navigate to the login page
    protected override async Task OnInitializedAsync()
    {
        // Redirect to login if not authenticated
        if (!UserSession.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        if (query["message"] == "delete")
        {
            successMessage = "Invoice deleted successfully.";
        }

        invoices = await Context.Invoices
            .Include(i => i.Client)
            .Include(i => i.InvoiceProducts)
            .Where(i => UserSession.UserId == i.UserId)
            .ToListAsync();

        isLoading = false;
    }

    // Method to calculate total amount for an invoice
    decimal GetTotal(Invoice invoice)
    {
        return invoice.InvoiceProducts.Sum(p => p.Quantity * p.Price);
    }

    // Method to navigate to the edit invoice page
    void EditInvoice(int id)
    {
        Navigation.NavigateTo($"/invoices/edit/{id}");
    }

    // Method to show confirmation modal for deleting an invoice
    void ShowConfirm(int id)
    {
        deleteId = id;
        showConfirm = true;
    }

    // Method to cancel the delete action and hide the confirmation modal
    void CancelDelete()
    {
        deleteId = null;
        showConfirm = false;
    }

    // Method to confirm deletion of an invoice, remove it from the database, and update the UI
    async Task ConfirmDelete()
    {
        if (deleteId == null)
            return;

        var invoice = await Context.Invoices.FindAsync(deleteId.Value);

        if (invoice != null)
        {
            Context.Invoices.Remove(invoice);
            await Context.SaveChangesAsync();

            invoices?.RemoveAll(i => i.InvoiceId == deleteId.Value);

            successMessage = $"Invoice #{deleteId.Value} deleted successfully.";
            showSuccess = true;

            StateHasChanged();

            await Task.Delay(2000);
            showSuccess = false;
            showConfirm = false;
        }
    }

    // Filter state
    string searchTerm = "";
    string statusFilter = "";
    DateTime? fromDate = null;
    DateTime? toDate = null;

    // Method to apply filters to the invoice list based on search term, status, and date range
    void ApplyFilters()
    {
        var query = Context.Invoices
            .Include(i => i.Client)
            .Include(i => i.InvoiceProducts)
            .Where(i => UserSession.UserId == i.UserId)
            .AsQueryable();

        // Search filter using case-insensitive matching
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            query = query.Where(i => EF.Functions.ILike(i.Client.ClientName, $"%{searchTerm}%"));
        }

        if (fromDate != null)
        {
            var fromUtc = DateTime.SpecifyKind(
                fromDate.Value.Date,
                DateTimeKind.Utc);

            query = query.Where(i => i.InvoiceDate >= fromUtc);
        }

        if (toDate != null)
        {
            var toUtc = DateTime.SpecifyKind(
                toDate.Value.Date.AddDays(1),
                DateTimeKind.Utc);

            query = query.Where(i => i.InvoiceDate < toUtc);
        }

        if (statusFilter == "paid")
        {
            query = query.Where(i => i.IsPaid);
        }
        else if (statusFilter == "unpaid")
        {
            query = query.Where(i => !i.IsPaid);
        }

        invoices = query.ToList();
    }

    // Method to clear all filters
    void ClearFilters()
    {
        searchTerm = "";
        statusFilter = "";
        fromDate = null;
        toDate = null;
        ApplyFilters();
    }

    // Sorting state
    private string sortOption = "";
    void SortBy(string option)
    {
        sortOption = option;

        if (option == "client-asc")
        {
            invoices = invoices?.OrderBy(i => i.Client.ClientName).ToList();
        }
        else if (option == "client-desc")
        {
            invoices = invoices?.OrderByDescending(i => i.Client.ClientName).ToList();
        }
        else if (option == "date-newest")
        {
            invoices = invoices?.OrderByDescending(i => i.InvoiceDate).ToList();
        }
        else if (option == "date-oldest")
        {
            invoices = invoices?.OrderBy(i => i.InvoiceDate).ToList();
        }
        else if (option == "total-high")
        {
            invoices = invoices?.OrderByDescending(i => GetTotal(i)).ToList();
        }
        else if (option == "total-low")
        {
            invoices = invoices?.OrderBy(i => GetTotal(i)).ToList();
        }
    }

}