@page "/account"

@using System.Globalization;
@using Microsoft.AspNetCore.Identity;
@using Microsoft.EntityFrameworkCore;
@using InvoiceTracker
@rendermode InteractiveServer
@inject InvoiceTrackerContext Db
@inject NavigationManager Navigation
@inject UserSession UserSession

<PageTitle>Account Details</PageTitle>

  @* When the user is not logged in show a loading message *@
  @if (isLoading)
  {
    <p>Loading...</p>
  }
  else if (currentUser == null)
  {
    <div class="alert alert-danger">
      No account found
    </div>
  }
  else
  {
    <div class="profile-card">

<h1>Account Details</h1> <br />
      @* Display user details when not editing, otherwise show the edit form *@
      @if (!isEditing)
      {
      <p>
        <strong>Company Name:</strong>
        @currentUser.CompanyName
      </p>

      <p>
        <strong>Email:</strong>
        @currentUser.CompanyEmail
      </p>

      <p>
        <strong>Phone:</strong>
        @currentUser.CompanyPhone
      </p>

      <p>
        <strong>Address:</strong><br />
        @currentUser.CompanyAddress<br />
        @currentUser.CompanyCity, @currentUser.CompanyState
      </p>

      <button class="btn btn-success" @onclick="(() => isEditing = true)">
        Edit Account
      </button>
      } 
      else
      {
      <EditForm EditContext="accountEditContext" OnSubmit="UpdateAccount" FormName="edit-account">
        <DataAnnotationsValidator />
        <div class="form-group">
            <label for="companyEmail">Email</label>
            <InputText 
              id="companyEmail" 
              class="form-control" 
              @bind-Value="currentUser.CompanyEmail" />
            <ValidationMessage For="@(() => currentUser.CompanyEmail)" />
        </div>

        <div class="form-group">
            <label for="companyPhone">Phone</label>
            <InputText 
              id="companyPhone" 
              class="form-control" 
              @bind-Value="currentUser.CompanyPhone" />
            <ValidationMessage For="@(() => currentUser.CompanyPhone)" />
        </div>

        <div class="form-group">
            <label for="companyAddress">Street Address</label>
            <InputText 
              id="companyAddress" 
              class="form-control" 
              @bind-Value="currentUser.CompanyAddress" />
            <ValidationMessage For="@(() => currentUser.CompanyAddress)" />
        </div>

        <div class="address-row">
            <div class="form-group">
                <label for="companyCity">City</label>
                <InputText 
                  id="companyCity" 
                  class="form-control" 
                  @bind-Value="currentUser.CompanyCity" />
                <ValidationMessage For="@(() => currentUser.CompanyCity)" />
            </div>

            <div class="form-group state-field">
                <label for="companyState">State</label>
                <InputText 
                  id="companyState" 
                  class="form-control" 
                  @bind-Value="currentUser.CompanyState" />
                <ValidationMessage For="@(() => currentUser.CompanyState)" />
            </div>
        </div>

        <button type="submit" class="btn btn-success" disabled="@(!isAccountInfoValid)">
            Save Changes
        </button>
        <ValidationSummary />
      </EditForm>
    }
    <div>
      <br />
      <h2>Change Password</h2>
      
      @* Display password change message *@
      @if (!string.IsNullOrEmpty(passwordMessage))
      {
        <div class="alert alert-info">
          @passwordMessage
        </div>
      }

        <EditForm EditContext="passwordEditContext" OnSubmit="ChangePassword" FormName="change-password">

        <DataAnnotationsValidator />

          <div class="form-group">
            <label for="currentPassword">Current Password</label>
            <InputText 
              id="currentPassword" 
              type="password" 
              class="form-control" 
              @bind-Value="changePassword.CurrentPassword" />
            <ValidationMessage For="@(() => changePassword.CurrentPassword)" />
          </div>

          <div class="form-group">
            <label for="newPassword">New Password</label>
            <InputText 
              id="newPassword" 
              type="password" 
              class="form-control" 
              @bind-Value="changePassword.NewPassword" />
            <ValidationMessage For="@(() => changePassword.NewPassword)" />
          </div>

          <div class="form-group">
            <label for="confirmPassword">Confirm New Password</label>
            <InputText 
              id="confirmPassword" 
              type="password" 
              class="form-control" 
              @bind-Value="changePassword.ConfirmPassword" />
            <ValidationMessage For="@(() => changePassword.ConfirmPassword)" />
          </div>

          <button type="submit" class="btn btn-warning" disabled="@(!isPasswordChangeValid)">
            Change Password
          </button>
        </EditForm>
      </div>

  </div>
}


@code {
  private User? currentUser;
  private ChangePasswordModel changePassword = new();
  private string passwordMessage = "";
  private bool isEditing = false;
  private bool isLoading = true;
  private readonly PasswordHasher<User> _passwordHasher = new();
  private bool isAccountInfoValid =>
      currentUser is not null &&
      !string.IsNullOrWhiteSpace(currentUser.CompanyEmail) &&
      !string.IsNullOrWhiteSpace(currentUser.CompanyPhone) &&
      !string.IsNullOrWhiteSpace(currentUser.CompanyAddress) &&
      !string.IsNullOrWhiteSpace(currentUser.CompanyCity) &&
      !string.IsNullOrWhiteSpace(currentUser.CompanyState);
  private bool isPasswordChangeValid =>
      !string.IsNullOrWhiteSpace(changePassword.CurrentPassword) &&
      !string.IsNullOrWhiteSpace(changePassword.NewPassword) &&
      !string.IsNullOrWhiteSpace(changePassword.ConfirmPassword) &&
      changePassword.NewPassword == changePassword.ConfirmPassword;

  private EditContext? accountEditContext;
  private EditContext? passwordEditContext;

  // On component initialization, check if the user is authenticated. 
  // If not, redirect to the login page. If authenticated, load the user's details.
  protected override async Task OnInitializedAsync()
  {
    if (!UserSession.IsAuthenticated)
    {
      Navigation.NavigateTo("/login");
    }
    await LoadUser();
    accountEditContext = new EditContext(currentUser!);
    passwordEditContext = new EditContext(changePassword);

    accountEditContext.OnFieldChanged += (_, __) => StateHasChanged();
    passwordEditContext.OnFieldChanged += (_, __) => StateHasChanged();
    isLoading = false;
  }

  // Load the current user's details from the database based on the UserSession's UserId
  private async Task LoadUser()
  {
    try
    {
      currentUser = await Db.Users
        .FirstOrDefaultAsync(u => u.UserId == UserSession.UserId);
    }
    catch (Exception ex)
    {
      Console.WriteLine($"Error loading user: {ex.Message}");
    }
  }

  // Navigate to the edit account page 
  //(not currently used since editing is done inline, but could be useful if we want a separate edit page in the future)
  private void EditAccount()
  {
    Navigation.NavigateTo("/edit-account");
  }

  // Save the updated account details to the database and reload the user information
  private async Task UpdateAccount()
  {
    Console.WriteLine("Updating account");
    if (currentUser is null)
      return;

    if (string.IsNullOrWhiteSpace(currentUser.CompanyEmail) ||
        string.IsNullOrWhiteSpace(currentUser.CompanyPhone) ||
        string.IsNullOrWhiteSpace(currentUser.CompanyAddress) ||
        string.IsNullOrWhiteSpace(currentUser.CompanyCity) ||
        string.IsNullOrWhiteSpace(currentUser.CompanyState))
    {
      return;
    }

    await Db.SaveChangesAsync();
    await LoadUser();
    isEditing = false;
    await InvokeAsync(StateHasChanged);

  }

  // Change the user's password. 
  // It first verifies that the current password is correct, and if so, hashes the new password and saves it to the database.
  private async Task ChangePassword()
  {
    if (currentUser == null)
      return;

    if (string.IsNullOrWhiteSpace(changePassword.CurrentPassword) ||
        string.IsNullOrWhiteSpace(changePassword.NewPassword) ||
        string.IsNullOrWhiteSpace(changePassword.ConfirmPassword))
      return;

    
    var result = _passwordHasher.VerifyHashedPassword(
          currentUser,
          currentUser.Password,
          changePassword.CurrentPassword);

    if (result == PasswordVerificationResult.Failed)
    {
      passwordMessage = "Current password is incorrect.";
      return;
    }

    currentUser.Password =
        _passwordHasher.HashPassword(
          currentUser,
          changePassword.NewPassword);
    try
    {
      await Db.SaveChangesAsync();
      await LoadUser();
      passwordMessage = "Password changed successfully.";

      changePassword = new ChangePasswordModel();
    }
    catch (Exception ex)
    {
      passwordMessage = "Error saving password. Please try again.";
      Console.WriteLine($"Error changing password: {ex.Message}");
    }
  }
}